FLASK_ENV=development
FLASK_CONFIG=development

# Flask secret key
# IMPORTANT: Set this to a strong random value in production and Docker.
SECRET_KEY=change-me-in-production

# Database configuration
# These values are shared between local development and Docker Compose.
DB_NAME=hawkeye_db
DB_USER=hawkeye_user
DB_PASSWORD=CHANGE_ME_PASSWORD

# Application DATABASE_URL used by Flask.
# When using Docker Compose, these values will also be used inside the container.
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}
# For running the app via Docker Compose, the web container uses a DATABASE_URL
# constructed from DB_NAME/DB_USER/DB_PASSWORD with the host set to \"db\".

# Google Maps (Places Autocomplete, map pin for incident location)
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
GOOGLE_MAPS_API_KEY=

# Mail settings (for notifications)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=hawkeye@example.com
